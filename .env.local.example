# ============================================================
# Ocean Orange — Environment Variables Template
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# ============================================================

# ---------------------------
# Stripe Payment Integration
# ---------------------------
# Your Stripe publishable key (safe to expose client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Your Stripe secret key (server-side only — keep private!)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# ---------------------------
# Printful API
# ---------------------------
# Your Printful API key for syncing products and fulfillment
PRINTFUL_API_KEY=your_printful_api_key_here

# ---------------------------
# Site Configuration
# ---------------------------
# The canonical URL of the deployed site (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.oceanorange.co.uk
